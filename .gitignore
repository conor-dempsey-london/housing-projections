# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

figures

data
output
.env

*.html

# Ignore everything generated under results/ except the final numerical
# estimates export (results/artifacts/az3_year_estimates/) — every
# intermediate directory has to be explicitly un-ignored too, or git never
# looks inside it to find the deeper negation.
results/*
!results/artifacts/
results/artifacts/*
!results/artifacts/az3_year_estimates/

scratch_upars.npy
notebooks/__marimo__/

# Internal working docs — only the stakeholder-facing summary is tracked
docs/*
!docs/az3-stakeholder-summary.md
!docs/az3-stakeholder-summary.pdf


# pixi environments
.pixi/*
!.pixi/config.toml
.gitattributes
.vscode/settings.json
pixi.lock

# Plan docs — internal working notes, not part of the shipped project
PLAN*.md
WORKPLAN.md

# Claude Code — local agent config/instructions, not part of the shipped project
CLAUDE.md
.claude/
