# Copy this file to .env and fill in the paths for your machine.
# .env is gitignored — never commit it.

# Required: absolute path to the repo root (used to anchor results/ and traces/)
PROJECT_ROOT=C:\Users\conor-dempsey\dev\housing-projections

# Required: root directory of the raw input data files
DATA_PATH=C:\Users\conor-dempsey\dev\housing-data

# Optional: override output locations (defaults to PROJECT_ROOT/results etc.)
# RESULTS_DIR=C:\Users\conor-dempsey\dev\housing-projections\results
# TRACES_DIR=C:\Users\conor-dempsey\dev\housing-projections\results\traces
# REPORT_PATH=C:\Users\conor-dempsey\dev\housing-projections\results\report.html
