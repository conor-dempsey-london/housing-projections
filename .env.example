# Copy this file to .env and fill in the paths for your machine.
# .env is gitignored — never commit it.

# Required: absolute path to the repo root (used to anchor results/ and traces/)
PROJECT_ROOT=/path/to/housing-projections

# Required: root directory of the raw input data files
DATA_PATH=/path/to/housing-data

# Optional: override output locations (defaults to PROJECT_ROOT/results etc.)
# RESULTS_DIR=
# TRACES_DIR=
# REPORT_PATH=
